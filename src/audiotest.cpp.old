//include <Arduino.h>
#include <AudioTools.h>

AudioInfo info(44100, 2, 16);
SineWaveGenerator<int16_t> sineWave(32000);      // subclass of SoundGenerator with max amplitude of 32000
GeneratedSoundStream<int16_t> sound(sineWave);   // Stream generated from sine wave
I2SStream out; 
StreamCopy copier(out, sound);   

// Define Amp Pins
#define AMP_I2S_DOUT 47
#define AMP_I2S_BCLK 48
#define AMP_I2S_LRC 45// copies sound into i2s

// Arduino Setup
void setup(void) {  
  // Open Serial 
  Serial.begin(9600);

  // start i2s
  Serial.println("starting I2S...");
  I2SConfig config = out.defaultConfig(TX_MODE);

  config.pin_bck = AMP_I2S_BCLK;
  config.pin_ws = AMP_I2S_LRC;
  config.pin_data = AMP_I2S_DOUT;

  config.copyFrom(info);
  out.begin(config);

  // Setup sine wave
  sineWave.begin(info, N_B4);
}

// Arduino loop - copy sound to out 
void loop() {
  copier.copy();
}